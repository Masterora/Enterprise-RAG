AGENT_SERVICE_TOKEN=replace-with-at-least-16-random-characters
# Optional fallback. Prefer configuring the key in Settings > Model Service.
OPENROUTER_API_KEY=replace-with-openrouter-api-key
RAG_AUTH_SECRET=replace-with-a-long-random-auth-secret
POSTGRES_DB=rag
POSTGRES_USER=rag
POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
# URL-encode special characters in the password used by this connection URI.
POSTGRES_DSN=postgresql://rag:replace-with-a-long-random-postgres-password@postgres:5432/rag?sslmode=disable
REDIS_PASSWORD=replace-with-at-least-16-random-characters
MINIO_ROOT_USER=rag-minio
MINIO_ROOT_PASSWORD=replace-with-a-long-random-minio-password

# Optional host port overrides.
API_HTTP_PORT=9999
WEB_HTTP_PORT=8080
POSTGRES_PORT=55432
REDIS_PORT=6379
NATS_PORT=4222
NATS_MONITOR_PORT=8222
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MILVUS_PORT=19530
MILVUS_HEALTH_PORT=9091
PROMETHEUS_PORT=9090
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
JAEGER_PORT=16686
GRAFANA_PORT=3000

# Optional OpenRouter endpoint used by both API and Agent services.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
